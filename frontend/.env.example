# URL da API
# Em desenvolvimento: deixe como /api (o proxy do Vite redireciona para localhost:3001)
# Em produção (Vercel): coloque a URL completa do seu backend, ex:
# VITE_API_URL=https://seu-backend.railway.app/api
VITE_API_URL=/api

# (Opcional) Alvo do proxy em desenvolvimento — padrão: http://localhost:3001
# VITE_DEV_API_TARGET=http://localhost:3001
